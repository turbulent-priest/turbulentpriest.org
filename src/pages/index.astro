---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Turbulent Priest';
const description = 'Applied-AI writing — the questions the roadmaps skip. Philosophy, ethics, and craft, from someone who thinks the philosophy is the work.';
const permalink = Astro.site.href;
---

<BaseLayout title={title} description={description} permalink={permalink}>
  <div class="home">
    <h1>The philosophy is the work.</h1>
    <p class="lede">
      Applied-AI writing — the questions the roadmaps skip. Epistemology, ethics,
      craft, and consequences, from a turbulent priest with a keyboard.
    </p>
    <p class="home-links">
      <a href="/blog">Read the writing &rarr;</a>
    </p>
  </div>
</BaseLayout>

<style>
  .home {
    flex: 1;
    width: 100%;
    max-width: 42em;
    margin: 0 auto;
    padding: 3rem 0 2rem;
  }
  .home h1 {
    margin-bottom: 0.5rem;
  }
  .lede {
    font-size: 1.35rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }
  .home-links {
    font-family: var(--font-family-sans);
    font-weight: 700;
    margin-top: 1.6rem;
  }
  .home-links a {
    text-decoration: none;
  }

  @media (max-width: 800px) {
    .home h1 {
      font-size: 2.6em;
    }
  }
</style>
