<footer>
  <span>
    &copy; {new Date().getFullYear()} Turbulent Priest &middot;
    <a href="/colophon">Colophon</a> &middot;
    <a class="contact-link" data-user="confession" data-domain="turbulentpriest.org" href="#">Contact</a> &middot;
    <em>written with named collaborators, not autocomplete.</em>
  </span>
</footer>

<script>
  // Assemble the mailto at runtime so the full address stays out of the static HTML (spam-harvest resistance).
  document.querySelectorAll('a.contact-link').forEach((a) => {
    const el = a as HTMLAnchorElement;
    el.href = `mailto:${el.dataset.user}@${el.dataset.domain}`;
  });
</script>

<style>
  footer {
    color: var(--text-secondary);
    font-size: .8em;
    margin: 1em auto;
    max-width: 1400px;
    padding: 1em 2em;
    text-align: center;
    width: 100%;
  }
</style>
